<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#8E6B8F" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pet Profile"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textColor="#4B3B4F"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- IMAGE -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPet"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:src="@drawable/profile"
            android:scaleType="centerCrop"
            android:background="@drawable/profile_bg"
            android:padding="4dp"
            app:shapeAppearanceOverlay="@style/circleImage" />

        <!-- NAME -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="26sp"
            android:textColor="#4B3B4F"
            android:layout_gravity="center"
            android:layout_marginTop="14dp" />

        <!-- SPECIES -->
        <TextView
            android:id="@+id/tvSpecies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#9C8B9C"
            android:layout_gravity="center"
            android:layout_marginTop="4dp" />

        <!-- OWNER -->
        <TextView
            android:id="@+id/tvOwner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#C2A9B5"
            android:layout_gravity="center"
            android:layout_marginTop="3dp" />

        <!-- APPOINTMENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="28dp"
            android:background="@drawable/card_bg"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upcoming Appointment"
                android:textColor="#F8EFFF"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="General Check-up"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="21sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21 April • 09:00 AM"
                android:textColor="#F5E8F0"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- MEDICAL RECORDS TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medical Records"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#4B3B4F"
            android:layout_marginTop="30dp" />

        <!-- RECORDS CONTAINER -->
        <LinearLayout
            android:id="@+id/recordsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp" />

        <!-- MEDICATIONS TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medications &amp; Vaccines"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#4B3B4F"
            android:layout_marginTop="30dp" />

        <!-- MEDICATION CONTAINER -->
        <LinearLayout
            android:id="@+id/medContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp" />

    </LinearLayout>

</ScrollView>